==== LOG ====

1     libname d 'data';
NOTE: Libref D was successfully assigned as follows:
            Engine:        PARQUET
            Physical Name: data

2     proc sql;
3       create table work.tall  as select name, height from d.class where height > 65;
4       create table work.heavy as select name, weight from d.class where weight > 100;
5       select a.name, a.height, b.weight
6       from work.tall as a
7       inner join work.heavy as b
8       on a.name = b.name
9       order by a.name;
10    quit;
