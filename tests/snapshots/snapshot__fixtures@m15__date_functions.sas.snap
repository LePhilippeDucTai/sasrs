==== LOG ====

1     data work.test;
2       /* DATEPART/TIMEPART — decompose datetime */
3       dt = dhms(21710, 14, 30, 45);  /* 2020-01-01 14:30:45 */
4       dp = datepart(dt);             /* Should be 21710 (SAS date) */
5       tp = timepart(dt);             /* Should be ~52245 (14:30:45 in seconds) */
6     
7       /* DATETIME/HMS/DHMS — construct datetime */
8       time_hms = hms(14, 30, 45);    /* Should be ~52245 seconds */
9       dt_rebuild = datetime(21710, time_hms);  /* Rebuild datetime */
10    
11      /* HMS edge cases */
12      time_midnight = hms(0, 0, 0);  /* Should be 0 */
13      time_end = hms(23, 59, 59);    /* Should be 86399 */
14    
15      /* JULDATE — day of year */
16      sas_date_1 = 21710;            /* 2020-01-01 */
17      jul_1 = juldate(sas_date_1);   /* Should be 1 */
18      sas_date_2 = 21710 + 364;      /* 2020-12-30 (leap year) */
19      jul_2 = juldate(sas_date_2);   /* Should be 365 */
20    
21      /* DATEJUL — inverse */
22      dj_20001 = datejul(20001);     /* year 2000, day 1 = 2000-01-01 */
23      dj_07365 = datejul(07365);     /* year 2007, day 365 */
24    
25      /* YRDIF/DATDIF — differences */
26      date1 = 21710;                 /* 2020-01-01 */
27      date2 = 21710 + 365;           /* 2021-01-01 (1 year later) */
28      yrdif_actual = yrdif(date1, date2, 'ACTUAL');  /* Should be ~1.0 */
29      datdif_actual = datdif(date1, date2, 'ACTUAL');  /* Should be 365 */
30    
31      /* HOUR/MINUTE/SECOND — extract time components */
32      dt_test = dhms(21710, 14, 30, 45);  /* 2020-01-01 14:30:45 */
33      hr = hour(dt_test);            /* Should be 14 */
34      mn = minute(dt_test);          /* Should be 30 */
35      sc = second(dt_test);          /* Should be 45 */
36    
37      /* NLDATE — format as text */
38      nl_en = nldate(21710, 'EN');   /* Should be "01JAN2020" */
39      nl_default = nldate(21710);    /* Default EN: "01JAN2020" */
40    
41      output;
42    run;
