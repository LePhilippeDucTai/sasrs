17      call label(age, lbl);   /* lbl should be 'Age in years' */
18    
19      /* CALL CATS — concatenate items into a character variable */
20      a = 'hello';
21      b = 'world';
22      call cats(result, a, ' ', b);  /* result should be 'helloworld' (CATS strips) */
23    
24      /* CALL SCAN — extract nth word from string */
25      str = 'the quick brown fox';
26      call scan(str, 2, word);  /* word should be 'quick' */
27    
28      /* CALL SORTN — sort numeric variables in place (ascending) */
29      array nums{3} n1-n3;
30      n1 = 3; n2 = 1; n3 = 2;
31      call sortn(nums);   /* nums should be 1, 2, 3 */
32    
33      /* CALL SORTC — sort character variables in place (ascending) */
34      c1 = 'c'; c2 = 'a'; c3 = 'b';
35      call sortc(c1, c2, c3);  /* should be 'a', 'b', 'c' */
36    
37      /* CALL SYMPUTX — write variable to macro symbol (like SYMPUT) */
38      val = 55;
39      call symputx('mymacro', val);  /* &mymacro should be 55 after step */
40    
41      keep name lbl result word n1 n2 n3 c1 c2 c3;
42      output;
