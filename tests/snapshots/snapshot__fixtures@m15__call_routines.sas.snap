==== LOG ====

1     data work.test;
2       length name $32 lbl $40 result $20 word $10 c1 $1 c2 $1 c3 $1;
3     
4       /* CALL MISSING — set variables to missing */
5       x = 42;
6       y = 'hello';
7       call missing(x, y);
8       /* x and y should now be missing */
9     
10      /* CALL VNAME — get variable name by reference */
